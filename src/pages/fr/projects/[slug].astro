---
import ProjectDetail from '@/components/features/projects/ProjectDetail.astro';
import { getLocalizedProjectPaths } from '@/services/content';
import { type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
    return getLocalizedProjectPaths('fr');
}

interface Props {
    project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<ProjectDetail project={project} />
