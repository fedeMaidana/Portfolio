---
import ProjectDetail from '@/components/features/projects/ProjectDetail.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
    const all = await getCollection('projects');
    const base = all.filter((project: CollectionEntry<'projects'>) => !project.id.includes('/'));

    return base.map((esProject: CollectionEntry<'projects'>) => {
        const localized = all.find(
            (project: CollectionEntry<'projects'>) => project.id === `fr/${esProject.id}`
        );

        return {
            params: { slug: esProject.id },
            props: { project: localized ?? esProject },
        };
    });
}

interface Props {
    project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<ProjectDetail project={project} />
