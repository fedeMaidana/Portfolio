---
import ProjectDetail from '@/components/features/projects/ProjectDetail.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
    // El contenido en español vive en la raíz de la colección (ids sin
    // prefijo de locale), así las URLs históricas /projects/* no cambian.
    const projects = await getCollection(
        'projects',
        (project: CollectionEntry<'projects'>) => !project.id.includes('/')
    );

    return projects.map((project: CollectionEntry<'projects'>) => ({
        params: { slug: project.id },
        props: { project },
    }));
}

interface Props {
    project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<ProjectDetail project={project} />
