---
import ProjectDetail from '@/components/features/projects/ProjectDetail.astro';
import { DEFAULT_LOCALE } from '@/i18n/ui';
import { getLocalizedProjectPaths } from '@/services/content';
import { type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
    return getLocalizedProjectPaths(DEFAULT_LOCALE);
}

interface Props {
    project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<ProjectDetail project={project} />
