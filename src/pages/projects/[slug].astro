---
import Card from '@/components/ui/Card.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
    const projects = await getCollection('projects');
    return projects.map((project: CollectionEntry<'projects'>) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

interface Props {
    project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<Layout title={`${project.data.title} | Fede Maidana`} description={project.data.description}>
    <main class="project-container">
        <Card tag="header" class="header-card">
            <a href="/" class="back-link">
                <span class="back-arrow" aria-hidden="true">←</span>
                <span>Volver al inicio</span>
            </a>

            <div class="title-block">
                <span class="project-number">{project.data.number}</span>
                <h1>{project.data.title}</h1>
            </div>

            <p class="project-description">{project.data.description}</p>

            <div class="meta">
                <span class="category-badge"
                    >{project.data.category.replace('Application', '')}</span
                >
                {
                    project.data.tags && (
                        <div class="tags">
                            {project.data.tags.map((tag: string) => (
                                <span class="tag">{tag}</span>
                            ))}
                        </div>
                    )
                }
            </div>

            <div class="actions">
                {
                    project.data.link && project.data.link !== '#' && (
                        <a
                            href={project.data.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="action-link primary"
                        >
                            Ver Proyecto
                        </a>
                    )
                }
                {
                    project.data.repoUrl && project.data.repoUrl !== '#' && (
                        <a
                            href={project.data.repoUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="action-link secondary"
                        >
                            Código Fuente
                        </a>
                    )
                }
            </div>
        </Card>

        <Card class="article-card">
            <article class="prose">
                <Content />
            </article>
        </Card>
    </main>
</Layout>

<style>
    /*
     * Entry animation starts after 150ms delay.
     * The overlay from ProjectCard fades out over 350ms on astro:page-load.
     * The 150ms delay lets the overlay start fading before content slides up,
     * creating a reveal effect where they overlap.
     */

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .project-container {
        max-width: 760px;
        margin: 0 auto;
        padding: 6rem 2rem 5rem;
        position: relative;
        animation: slideUp 0.6s cubic-bezier(0.22, 0.61, 0.36, 1) 0.15s both;
    }

    .project-container :global(.glass) {
        animation: none;
        opacity: 1;
    }

    @media (prefers-reduced-motion: reduce) {
        .project-container {
            animation: none;
        }
    }

    :global(.header-card):hover,
    :global(.article-card):hover {
        transform: none !important;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--text-muted);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        margin-block-end: 2rem;
        padding: 0.5rem 0;
        transition: color var(--transition-base);
    }

    .back-link:hover {
        color: var(--accent);
    }

    .back-arrow {
        display: inline-block;
        transition: transform var(--transition-base);
    }

    .back-link:hover .back-arrow {
        transform: translateX(-4px);
    }

    .title-block {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        margin-block-end: 1.25rem;
    }

    .project-number {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--accent);
        letter-spacing: 0.05em;
        opacity: 0.7;
    }

    .title-block h1 {
        font-family: var(--font-serif);
        font-size: clamp(2.25rem, 5vw + 1rem, 3.5rem);
        font-weight: 400;
        color: var(--text);
        line-height: 1.1;
    }

    .project-description {
        font-size: var(--text-sm);
        line-height: 1.7;
        color: var(--text-muted);
        max-width: 60ch;
        margin-block-end: 1.75rem;
    }

    .meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.75rem;
        margin-block-end: 2rem;
    }

    .category-badge {
        font-family: var(--font-mono);
        font-size: var(--text-xxs);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent);
        padding: 0.3rem 0.7rem;
        border: 1px solid var(--accent-hover-border);
        border-radius: 100px;
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tag {
        font-family: var(--font-mono);
        font-size: var(--text-xxs);
        color: var(--text-muted);
        padding: 0.25rem 0.6rem;
        border-radius: 100px;
        background-color: var(--card-bg);
        border: 1px solid var(--card-border);
    }

    .actions {
        display: flex;
        gap: 1rem;
    }

    .action-link {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        text-decoration: none;
        padding: 0.6rem 1.25rem;
        border-radius: var(--radius-sm);
        transition: all var(--transition-base);
        letter-spacing: 0.02em;
    }

    .action-link.primary {
        background-color: var(--accent);
        color: var(--bg);
        border: 1px solid var(--accent);
    }

    .action-link.primary:hover {
        opacity: 0.85;
        transform: translateY(-2px);
    }

    .action-link.secondary {
        color: var(--text-muted);
        border: 1px solid var(--card-border);
        background-color: transparent;
    }

    .action-link.secondary:hover {
        color: var(--text);
        border-color: var(--text-muted);
        transform: translateY(-2px);
    }

    .prose {
        font-size: 1.05rem;
        line-height: 1.85;
    }

    .prose :global(p) {
        margin-block-end: 1.75rem;
        color: color-mix(in srgb, var(--text), transparent 18%);
    }

    .prose :global(h2),
    .prose :global(h3) {
        font-family: var(--font-serif);
        color: var(--text);
        font-weight: 400;
    }

    .prose :global(h2) {
        font-size: var(--text-h2);
        margin-block-start: 4rem;
        margin-block-end: 1.5rem;
    }

    .prose :global(h3) {
        font-size: var(--text-h3);
        margin-block-start: 3rem;
        margin-block-end: 1.25rem;
    }

    .prose :global(ul) {
        margin-block-end: 2.25rem;
        padding-inline-start: 1.5rem;
        list-style: none;
    }

    .prose :global(li) {
        position: relative;
        margin-block-end: 0.9rem;
        color: color-mix(in srgb, var(--text), transparent 25%);
        line-height: 1.75;
    }

    .prose :global(li::before) {
        content: '—';
        position: absolute;
        left: -1.5rem;
        color: var(--accent);
        font-weight: bold;
        opacity: 0.6;
    }

    .prose :global(strong) {
        color: var(--text);
        font-weight: 600;
    }

    .prose :global(code) {
        font-family: var(--font-mono);
        background-color: var(--card-bg);
        border: 1px solid var(--card-border);
        padding: 0.15rem 0.4rem;
        border-radius: var(--radius-sm);
        font-size: 0.85em;
        color: var(--accent);
    }

    .prose :global(a) {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: color-mix(in srgb, var(--accent), transparent 60%);
        transition: text-decoration-color var(--transition-base);
    }

    .prose :global(a:hover) {
        text-decoration-color: var(--accent);
    }

    @media (max-width: 600px) {
        .project-container {
            padding: 4rem 1.5rem 3rem;
        }

        .title-block {
            flex-direction: column;
            gap: 0.25rem;
        }

        .actions {
            flex-direction: column;
        }

        .action-link {
            text-align: center;
        }
    }
</style>

<script>
    function clearContainerAnimation() {
        const container = document.querySelector('.project-container') as HTMLElement | null;
        if (!container) return;

        container.addEventListener(
            'animationend',
            () => {
                container.style.animation = 'none';
                container.style.opacity = '1';
            },
            { once: true }
        );
    }

    clearContainerAnimation();
    document.addEventListener('astro:page-load', clearContainerAnimation);
</script>
