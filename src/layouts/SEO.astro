---
import { LOCALES } from '@/i18n/ui';
import { getLangFromUrl, pathForLocale, useTranslations } from '@/i18n/utils';
import { getPersonSchema } from '@/utils/schema';

interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const {
    title = t('meta.title'),
    description = t('meta.description'),
    image = '/pictures/seo-1.jpeg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const personSchema = getPersonSchema(Astro.site, t('meta.personDescription'));

const ogLocale = lang === 'en' ? 'en_US' : 'es_AR';
const ogLocaleAlternate = lang === 'en' ? 'es_AR' : 'en_US';

const alternates = LOCALES.map((locale) => ({
    locale,
    href: new URL(pathForLocale(Astro.url.pathname, locale), Astro.site),
}));
const defaultHref = new URL(pathForLocale(Astro.url.pathname, 'es'), Astro.site);
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonicalURL} />

{alternates.map(({ locale, href }) => <link rel="alternate" hreflang={locale} href={href} />)}
<link rel="alternate" hreflang="x-default" href={defaultHref} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="Federico Maidana" />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlternate} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:alt" content="Federico Maidana — Backend Developer" />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

<script type="application/ld+json" set:html={personSchema} />

<link rel="sitemap" href="/sitemap-index.xml" />
