---
import '@/assets/styles/global.css';
import NoiseOverlay from '@/components/ui/NoiseOverlay.astro';
import SkipLink from '@/components/ui/SkipLink.astro';
import WaveCanvas from '@/components/ui/WaveCanvas.astro';
import SEO from '@/layouts/SEO.astro';
import Analytics from '@vercel/analytics/astro';

import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource/instrument-serif/400.css';
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';

import fontInstSerifItalic from '@fontsource/instrument-serif/files/instrument-serif-latin-400-italic.woff2?url';
import fontInstSerif400 from '@fontsource/instrument-serif/files/instrument-serif-latin-400-normal.woff2?url';
import fontSpaceMono400 from '@fontsource/space-mono/files/space-mono-latin-400-normal.woff2?url';
import fontSpaceMono700 from '@fontsource/space-mono/files/space-mono-latin-700-normal.woff2?url';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'Federico Maidana | Portafolio',
    description = 'Backend Developer enfocado en rendimiento y código seguro. Mar del Plata, Argentina.',
} = Astro.props;
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <link
            rel="preload"
            href={fontSpaceMono400}
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <link
            rel="preload"
            href={fontSpaceMono700}
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <link
            rel="preload"
            href={fontInstSerif400}
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <link
            rel="preload"
            href={fontInstSerifItalic}
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />

        <SEO title={title} description={description} />
    </head>

    <body>
        <NoiseOverlay />
        <WaveCanvas />
        <SkipLink />
        <slot />
        <Analytics />
    </body>
</html>
