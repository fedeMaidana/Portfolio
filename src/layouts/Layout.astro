---
import '@/assets/styles/global.css';
import Fonts from '@/components/ui/Fonts.astro';
import NoiseOverlay from '@/components/ui/NoiseOverlay.astro';
import SkipLink from '@/components/ui/SkipLink.astro';
import WaveCanvas from '@/components/ui/WaveCanvas.astro';
import SEO from '@/layouts/SEO.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'Federico Maidana | Portafolio',
    description = 'Backend Developer enfocado en rendimiento y código seguro. Mar del Plata, Argentina.',
} = Astro.props;
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="icon" href="/favicon.ico" sizes="32x32" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

        <Fonts />

        <SEO title={title} description={description} />
        <ClientRouter />
    </head>

    <body>
        <NoiseOverlay />
        <WaveCanvas />
        <SkipLink />
        <slot />
        <Analytics />
        <SpeedInsights />
    </body>
</html>
