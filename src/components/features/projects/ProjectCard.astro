---
import { getSoftwareSchema } from '@/utils/schema';
import { type CollectionEntry } from 'astro:content';
import ArrowIcon from '../../ui/icons/ArrowIcon.astro';
import FolderIcon from '../../ui/icons/FolderIcon.astro';
import GithubIcon from '../../ui/icons/GithubIcon.astro';
import LinkIcon from '../../ui/icons/LinkIcon.astro';
import Pill from '../../ui/Pill.astro';

interface Props {
    project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, number, link = '#', repoUrl = '#', description, category } = project.data;
const isCurrent = number === '#001';

const softwareSchema = getSoftwareSchema({
    title,
    description,
    category,
    url: link !== '#' ? link : Astro.url.href,
    repoUrl,
});
---

<article class="work-card">
    <script type="application/ld+json" set:html={softwareSchema} />
    <FolderIcon class="folder-bg" />

    <div class="card-content">
        <span class="tag" aria-hidden="true">{number}</span>
        <h3 class="name">{title}</h3>

        <div class="status-pill">
            {
                isCurrent ? (
                    <Pill class="current-label">
                        <span>Estás aquí</span>
                    </Pill>
                ) : (
                    <Pill href={link} aria-label={`Visitar web del proyecto ${title}`}>
                        <LinkIcon class="link" aria-hidden="true" />
                    </Pill>
                )
            }

            {
                repoUrl && (
                    <>
                        <div class="divider" aria-hidden="true" />
                        <Pill
                            href={repoUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={`Ver código fuente del proyecto ${title} en GitHub`}
                        >
                            <GithubIcon class="github" aria-hidden="true" />
                        </Pill>
                    </>
                )
            }
        </div>

        <a href={link} class="main-link" aria-label={`Ver detalles del proyecto ${title}`}>
            <ArrowIcon class="arrow" />
        </a>
    </div>
</article>

<style>
    @scope ( .work-card ) {
        :scope {
            container-type: inline-size;
            position: relative;
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
            aspect-ratio: 16 / 9;
            transition: all var(--transition-base);
        }

        :scope:hover,
        :scope:has(.main-link:focus-visible) {
            transform: translateY(-4px);
        }

        :scope:hover :global(.folder-bg path),
        :scope:has(.main-link:focus-visible) :global(.folder-bg path) {
            fill: var(--accent-hover-bg);
            stroke: var(--accent-hover-border);
        }

        .card-content {
            position: relative;
            z-index: 1;
            width: 100%;
            height: 100%;
        }

        .tag {
            position: absolute;
            top: 11.1%;
            left: 10%;
            transform: translate(-50%, -50%);
            font-family: var(--font-mono);
            font-size: var(--text-sm);
            color: var(--accent);
            letter-spacing: 0.05em;
        }

        .name {
            position: absolute;
            top: 11%;
            left: 24%;
            transform: translateY(-50%);
            font-family: var(--font-serif);
            font-size: var(--text-h3);
            font-weight: 400;
            color: var(--text);
            margin: 0;
            white-space: nowrap;
        }

        .status-pill {
            position: absolute;
            bottom: 1.5rem;
            left: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem 1rem;

            background: color-mix(in srgb, var(--card-bg) 80%, transparent);
            backdrop-filter: blur(4px);
            border: 1px solid var(--card-border);
            border-radius: 100px;
            transition: all var(--transition-base);
            cursor: pointer;
            z-index: 2;
        }

        .status-pill:hover,
        .status-pill:focus-within {
            transform: scale(1.1);
        }

        .status-pill :global(a) {
            transition:
                color var(--transition-base),
                transform var(--transition-base);
            display: inline-flex;
            border-radius: 50%;
        }

        .status-pill :global(a):hover,
        .status-pill :global(a):focus-visible {
            color: var(--text);
            transform: scale(1.15);
        }

        .status-pill :global(a):focus-visible {
            outline: 1px solid var(--accent);
            outline-offset: 4px;
        }

        .divider {
            width: 1px;
            height: 14px;
            background-color: var(--card-border);
        }

        .main-link {
            position: absolute;
            inset: 0;
            z-index: 1;
            display: block;
        }

        :scope:hover :global(.arrow),
        :scope:has(.main-link:focus-visible) :global(.arrow) {
            color: var(--accent);
            opacity: 1;
            transform: translateY(0) rotate(-45deg);
        }

        @container ( max-width: 380px ) {
            .name {
                font-size: var(--text-h3);
            }

            .current-label:global(.pill span) {
                display: none;
            }

            .status-pill {
                padding: 0.5rem;
                gap: 0.5rem;
            }
        }
    }
</style>
