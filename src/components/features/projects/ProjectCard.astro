---
import { getSoftwareSchema } from '@/utils/schema';
import { type CollectionEntry } from 'astro:content';
import ArrowIcon from '../../ui/icons/ArrowIcon.astro';
import FolderIcon from '../../ui/icons/FolderIcon.astro';
import GithubIcon from '../../ui/icons/GithubIcon.astro';
import LinkIcon from '../../ui/icons/LinkIcon.astro';
import Pill from '../../ui/Pill.astro';

interface Props {
    project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, number, link = '#', repoUrl = '#', description, category } = project.data;
const isCurrent = number === '#001';

const softwareSchema = getSoftwareSchema({
    title,
    description,
    category,
    url: link !== '#' ? link : Astro.url.href,
    repoUrl,
});
---

<article class="work-card">
    <script type="application/ld+json" set:html={softwareSchema} />
    <FolderIcon class="folder-bg" />

    <div class="card-content">
        <span class="tag" aria-hidden="true">{number}</span>
        <h3 class="name">{title}</h3>

        <div class="status-pill">
            {
                isCurrent ? (
                    <Pill class="current-label">
                        <span>Estás aquí</span>
                    </Pill>
                ) : (
                    <Pill href={link} aria-label={`Visitar web del proyecto ${title}`}>
                        <LinkIcon class="link" aria-hidden="true" />
                    </Pill>
                )
            }

            {
                repoUrl && (
                    <>
                        <div class="divider" aria-hidden="true" />
                        <Pill
                            href={repoUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={`Ver código fuente del proyecto ${title} en GitHub`}
                        >
                            <GithubIcon class="github" aria-hidden="true" />
                        </Pill>
                    </>
                )
            }
        </div>

        <a
            href={`/projects/${project.slug}`}
            class="main-link"
            aria-label={`Ver detalles del proyecto ${title}`}
        >
            <ArrowIcon class="arrow" />
        </a>
    </div>
</article>

<style>
    @scope ( .work-card ) {
        :scope {
            container-type: inline-size;
            position: relative;
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
            aspect-ratio: 16 / 9;
            transition: transform var(--transition-base);
        }

        :scope:hover,
        :scope:has(.main-link:focus-visible) {
            transform: translateY(-4px);
        }

        :scope:hover :global(.folder-bg path),
        :scope:has(.main-link:focus-visible) :global(.folder-bg path) {
            fill: var(--accent-hover-bg);
            stroke: var(--accent-hover-border);
        }

        .card-content {
            position: relative;
            z-index: 1;
            width: 100%;
            height: 100%;
        }

        .tag {
            position: absolute;
            top: 11.1%;
            left: 10%;
            transform: translate(-50%, -50%);
            font-family: var(--font-mono);
            font-size: var(--text-sm);
            color: var(--accent);
            letter-spacing: 0.05em;
            transition:
                opacity 0.3s ease,
                transform 0.3s ease;
        }

        .name {
            position: absolute;
            top: 11%;
            left: 24%;
            transform: translateY(-50%);
            font-family: var(--font-serif);
            font-size: var(--text-h3);
            font-weight: 400;
            color: var(--text);
            margin: 0;
            white-space: nowrap;
            transition:
                opacity 0.3s ease 0.04s,
                transform 0.3s ease 0.04s;
        }

        .status-pill {
            position: absolute;
            bottom: 1.5rem;
            left: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem 1rem;
            background: color-mix(in srgb, var(--card-bg) 80%, transparent);
            backdrop-filter: blur(4px);
            border: 1px solid var(--card-border);
            border-radius: 100px;
            transition:
                all var(--transition-base),
                opacity 0.3s ease 0.06s;
            cursor: pointer;
            z-index: 2;
        }

        .status-pill:hover,
        .status-pill:focus-within {
            transform: scale(1.1);
        }

        .status-pill :global(a) {
            transition:
                color var(--transition-base),
                transform var(--transition-base);
            display: inline-flex;
            border-radius: 50%;
        }

        .status-pill :global(a):hover,
        .status-pill :global(a):focus-visible {
            color: var(--text);
            transform: scale(1.15);
        }

        .status-pill :global(a):focus-visible {
            outline: 1px solid var(--accent);
            outline-offset: 4px;
        }

        .divider {
            width: 1px;
            height: 14px;
            background-color: var(--card-border);
        }

        .main-link {
            position: absolute;
            inset: 0;
            z-index: 1;
            display: block;
        }

        :scope:hover :global(.arrow),
        :scope:has(.main-link:focus-visible) :global(.arrow) {
            color: var(--accent);
            opacity: 1;
            transform: translateY(0) rotate(-45deg);
        }

        @container ( max-width: 380px ) {
            .name {
                font-size: var(--text-h3);
            }

            .current-label:global(.pill span) {
                display: none;
            }

            .status-pill {
                padding: 0.5rem;
                gap: 0.5rem;
            }
        }

        /* ─── Step 1: Content fades ─── */

        :scope.is-exiting .tag,
        :scope.is-exiting .name,
        :scope.is-exiting .status-pill,
        :scope.is-exiting :global(.arrow) {
            opacity: 0;
            transform: translateY(8px);
            pointer-events: none;
        }

        /* ─── Step 2: SVG morphs shape ─── */

        :scope.is-morphing :global(.folder-bg path) {
            d: path(
                'M 8,0 L 152,0 Q 160,0 160,8 L 160,82 Q 160,90 152,90 L 152,90 Q 152,90 152,90 L 152,90 Q 152,90 132,90 L 8,90 Q 0,90 0,82 L 0,8 Q 0,0 8,0 L 8,0 Q 8,0 8,0 L 8,0 Q 8,0 8,0 Z'
            );
            stroke: transparent;
            transition:
                d 0.55s cubic-bezier(0.22, 0.61, 0.36, 1),
                stroke 0.3s ease;
        }
    }

    /*
     * Overlay styles — element is appended to <body> via JS.
     *
     * Default state: glass effect matching .glass cards.
     * .is-expanding: transitions glass → solid var(--bg)
     *                during the grow-to-viewport phase.
     */

    :global(#card-expand-overlay) {
        background-color: var(--card-bg);
        backdrop-filter: blur(28px) saturate(130%);
        border: 1px solid var(--card-border);
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.1);
    }

    :global(#card-expand-overlay.is-expanding) {
        background-color: var(--bg);
        backdrop-filter: blur(60px) saturate(100%);
        border-color: transparent;
        box-shadow: none;
    }
</style>

<script>
    /*
     * Animation timeline (more deliberate pacing):
     *
     * t=0ms        Content starts fading
     * t=350ms      Content gone.
     *              SVG morph starts (folder → rectangle, 550ms).
     *              Glass overlay created at card position, opacity=0.
     * t=550ms      Overlay starts fading in (200ms delay lets morph be visible).
     * t=900ms      SVG morphed. Overlay fully opaque (glass).
     * t=1050ms     Breathing pause (150ms).
     * t=1050ms     Overlay expands to viewport. Glass → solid var(--bg).
     * t=1700ms     Navigate.
     *
     * On destination page (astro:page-load):
     *              Overlay fades out over 350ms instead of instant remove.
     *              This gives .glass cards time to composite backdrop-filter.
     *
     * Overlay is appended to <body> (not inside .glass) because
     * backdrop-filter creates a containing block that breaks position:fixed.
     */

    let isTransitioning = false;

    function wait(ms: number): Promise<void> {
        return new Promise((resolve) => setTimeout(resolve, ms));
    }

    async function handleCardClick(e: Event) {
        e.preventDefault();
        if (isTransitioning) return;

        const link = e.currentTarget as HTMLAnchorElement;
        const card = link.closest('.work-card') as HTMLElement | null;
        if (!card) return;

        const href = link.getAttribute('href');
        if (!href) return;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            window.location.href = href;
            return;
        }

        isTransitioning = true;

        // Prefetch
        const prefetchLink = document.createElement('link');
        prefetchLink.rel = 'prefetch';
        prefetchLink.href = href;
        document.head.appendChild(prefetchLink);

        // ── Step 1: Fade out content ──
        card.classList.add('is-exiting');
        await wait(350);

        // ── Step 2: Morph SVG + create overlay simultaneously ──
        const rect = card.getBoundingClientRect();

        // Create glass overlay at card position (invisible for now)
        const overlay = document.createElement('div');
        overlay.id = 'card-expand-overlay';
        Object.assign(overlay.style, {
            position: 'fixed',
            top: `${rect.top}px`,
            left: `${rect.left}px`,
            width: `${rect.width}px`,
            height: `${rect.height}px`,
            borderRadius: 'var(--radius-lg)',
            zIndex: '99999',
            pointerEvents: 'none',
            opacity: '0',
        });
        document.body.appendChild(overlay);

        // Start SVG morph
        card.classList.add('is-morphing');

        // Let the morph be visible for 200ms, then fade overlay in
        await wait(200);

        // Fade overlay in over 350ms (as SVG finishes morphing underneath)
        overlay.style.transition = 'opacity 0.35s ease';
        overlay.style.opacity = '1';
        await wait(350);

        // ── Breathing pause ──
        await wait(150);

        // ── Step 3: Expand overlay to viewport ──
        const dur = '0.65s';
        const ease = 'cubic-bezier(0.22, 0.61, 0.36, 1)';
        overlay.style.transition = [
            `top ${dur} ${ease}`,
            `left ${dur} ${ease}`,
            `width ${dur} ${ease}`,
            `height ${dur} ${ease}`,
            `border-radius ${dur} ${ease}`,
            `background-color ${dur} ${ease}`,
            `backdrop-filter ${dur} ${ease}`,
            `border-color ${dur} ${ease}`,
            `box-shadow ${dur} ${ease}`,
        ].join(', ');

        overlay.classList.add('is-expanding');
        Object.assign(overlay.style, {
            top: '0px',
            left: '0px',
            width: '100vw',
            height: '100vh',
            borderRadius: '0px',
        });

        await wait(600);

        // ── Step 4: Navigate ──
        const noFlash = document.createElement('style');
        noFlash.id = 'card-transition-override';
        noFlash.textContent = [
            '::view-transition-old(root) { animation: none !important; opacity: 0 !important; }',
            '::view-transition-new(root) { animation: none !important; }',
        ].join('\n');
        document.head.appendChild(noFlash);

        try {
            const { navigate } = await import('astro:transitions/client');
            navigate(href);
        } catch {
            window.location.href = href;
        }
    }

    function cleanup() {
        isTransitioning = false;
        document.getElementById('card-transition-override')?.remove();

        // Fade overlay out instead of instant remove.
        // This keeps it visible while the new page's .glass cards
        // composite their backdrop-filter (needs at least 1-2 frames).
        const overlay = document.getElementById('card-expand-overlay');
        if (overlay) {
            overlay.style.transition = 'opacity 0.35s ease';
            overlay.style.opacity = '0';
            setTimeout(() => overlay.remove(), 400);
        }

        document.querySelectorAll('.work-card').forEach((card) => {
            card.classList.remove('is-exiting', 'is-morphing');
        });
    }

    function initProjectTransitions() {
        cleanup();
        document.querySelectorAll<HTMLAnchorElement>('.work-card .main-link').forEach((link) => {
            link.removeEventListener('click', handleCardClick);
            link.addEventListener('click', handleCardClick);
        });
    }

    initProjectTransitions();
    document.addEventListener('astro:page-load', initProjectTransitions);
</script>
