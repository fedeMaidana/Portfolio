---
interface Props {
    class?: string;
}

const { class: className } = Astro.props;
---

<svg
    class={className}
    viewBox="0 0 160 90"
    preserveAspectRatio="none"
    aria-hidden="true"
    role="img"
>
    <path
        d="
            M 40,0
            L 152,0 Q 160,0 160,8
            L 160,62 Q 160,70 152,70
            L 148,70 Q 140,70 140,78
            L 140,82 Q 140,90 132,90
            L 8,90   Q 0,90 0,82
            L 0,28   Q 0,20 8,20
            L 24,20  Q 32,20 32,12
            L 32,8   Q 32,0 40,0
            Z"
    ></path>
</svg>

<style>
    .folder-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        overflow: visible;
    }

    .folder-bg path {
        fill: color-mix(in srgb, var(--card-bg) 20%, transparent);
        stroke: var(--card-border, #ccc);
        stroke-width: 2px;
        vector-effect: non-scaling-stroke;
        transition: all 0.3s ease;
    }
</style>
