---
import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource/instrument-serif/400.css';
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';

import fontInstSerifItalic from '@fontsource/instrument-serif/files/instrument-serif-latin-400-italic.woff2?url';
import fontInstSerif400 from '@fontsource/instrument-serif/files/instrument-serif-latin-400-normal.woff2?url';
import fontSpaceMono400 from '@fontsource/space-mono/files/space-mono-latin-400-normal.woff2?url';
import fontSpaceMono700 from '@fontsource/space-mono/files/space-mono-latin-700-normal.woff2?url';
---

<link rel="preload" href={fontSpaceMono400} as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href={fontSpaceMono700} as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href={fontInstSerif400} as="font" type="font/woff2" crossorigin="anonymous" />
<link
    rel="preload"
    href={fontInstSerifItalic}
    as="font"
    type="font/woff2"
    crossorigin="anonymous"
/>
