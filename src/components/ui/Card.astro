---
interface Props {
    tag?: 'section' | 'header' | 'footer';
    id?: string;
    ariaLabelledby?: string;
    class?: string;
}

const { tag: Element = 'section', id, ariaLabelledby, class: className } = Astro.props;
---

<Element id={id} aria-labelledby={ariaLabelledby} class:list={['glass', 'fade-in', className]}>
    <slot />
</Element>

<style>
    @scope ( .glass ) {
        :scope {
            background-color: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-lg);
            -webkit-backdrop-filter: blur(28px) saturate(130%);
            backdrop-filter: blur(28px) saturate(130%);
            padding: 2rem;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.1);
            margin-block-end: 1.4rem;
            transition:
                background-color var(--transition-base),
                border-color var(--transition-base),
                box-shadow var(--transition-base),
                transform var(--transition-base);
        }

        :scope:hover {
            background-color: color-mix(in srgb, var(--text), transparent 94%);
            border-color: color-mix(in srgb, var(--text), transparent 88%);
            transform: translateY(-2px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
        }
    }

    @media (hover: none) {
        @scope ( .glass ) {
            :scope:hover {
                transform: none;
                box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.1);
            }
        }
    }

    @media (max-width: 600px) {
        @scope ( .glass ) {
            :scope {
                background-color: transparent;
                border: none;
                border-radius: 0;
                box-shadow: none;
                backdrop-filter: none;
                -webkit-backdrop-filter: none;
                margin-block-end: 0;
                padding: 1.5rem;
                position: relative;
            }

            :scope:not(:last-child)::after {
                content: '';
                display: block;
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 90%;
                height: 1px;
                background-color: var(--card-border);
            }

            :scope:hover {
                transform: none;
                background-color: transparent;
                box-shadow: none;
            }
        }
    }
</style>
