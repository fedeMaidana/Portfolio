---
import Card from '@/components/ui/Card.astro';
---

<Card class="about" ariaLabelledby="about-title">
    <h2 class="about-title">Sobre mí</h2>

    <div class="bio-container">
        <div class="trajectory">
            <span class="path-node past">Frontend</span>
            <span class="path-arrow" aria-hidden="true">→</span>
            <span class="path-node present">Backend</span>
        </div>

        <div class="bio-blocks">
            <p class="history">
                Pasé de construir interfaces a diseñar la
                <strong>arquitectura del servidor</strong>.
            </p>

            <div class="focus-block">
                <span class="focus-marker" aria-hidden="true">◆</span>
                <p class="current-focus">
                    Actualmente mi ecosistema principal es <strong>Rust</strong>. Diseño sistemas de
                    <strong>bajo nivel</strong> para maximizar el rendimiento y garantizar la seguridad
                    de memoria.
                </p>
            </div>

            <p class="perspective">
                Mi background en el cliente me permite diseñar <strong>APIs</strong> y arquitecturas
                <strong>Backend</strong> sin fricciones, pensadas para que los equipos de producto puedan
                utilizarlas sin problemas.
            </p>
        </div>
    </div>
</Card>

<style>
    @scope (.about) {
        .bio-container {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* ─── Trajectory ─── */

        .trajectory {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .path-node {
            font-family: var(--font-mono);
            font-size: var(--text-sm);
            font-weight: 700;
            padding: 0.3rem 0.75rem;
            border-radius: 100px;
            border: 1px solid var(--card-border);
            transition:
                border-color 0.3s ease,
                color 0.3s ease;
        }

        .path-node.past {
            color: var(--text-muted);
        }

        .path-node.present {
            color: var(--accent);
            border-color: var(--accent-hover-border);
            background-color: var(--accent-hover-bg);
        }

        .path-arrow {
            font-family: var(--font-mono);
            font-size: var(--text-sm);
            color: var(--text-muted);
            opacity: 0.4;
        }

        /* ─── Bio blocks ─── */

        .bio-blocks {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .history,
        .current-focus,
        .perspective {
            font-size: var(--text-sm);
            line-height: 1.8;
            color: color-mix(in srgb, var(--text), transparent 22%);

            & strong {
                color: color-mix(in srgb, var(--accent), transparent 10%);
                font-weight: 600;
            }
        }

        /* ─── Focus highlight ─── */

        .focus-block {
            display: flex;
            gap: 0.75rem;
            padding: 1rem 1.15rem;
            border-radius: var(--radius-md);
            background-color: color-mix(in srgb, var(--accent-hover-bg), transparent 40%);
            transition:
                background-color 0.3s ease,
                border-color 0.3s ease;
        }

        .focus-marker {
            flex-shrink: 0;
            font-size: 0.5rem;
            color: var(--accent);
            margin-block-start: 0.55rem;
            opacity: 0.6;
            transition: opacity 0.3s ease;
        }

        .focus-block .current-focus {
            margin: 0;
        }
    }

    @media (max-width: 600px) {
        @scope (.about) {
            .focus-block {
                padding: 0.85rem 1rem;
            }
        }
    }
</style>
