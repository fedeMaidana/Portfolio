---
import { getEntry } from 'astro:content';
import Card from '../ui/Card.astro';

const interestsEntry = await getEntry('interests', 'list');
const interests = interestsEntry.data.items;
---

<Card class="interests" ariaLabelledby="interests-title">
    <h2 class="interests-title">Intereses</h2>

    <ul class="interests-list">
        {
            interests.map((interest: string, i: number) => (
                <li style={`--delay: ${i * 0.04}s`}>
                    <span class="interest-label">{interest}</span>
                </li>
            ))
        }
    </ul>
</Card>

<style>
    @scope (.interests) {
        .interests-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .interests-list li {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            font-size: var(--text-xs);
            color: var(--text-muted);
            padding: 0.45rem 0.9rem;
            border-radius: 100px;
            border: 1px solid var(--card-border);
            background-color: color-mix(in srgb, var(--card-bg) 30%, transparent);
            cursor: default;
            transition:
                color 0.3s ease,
                border-color 0.3s ease,
                background-color 0.3s ease,
                transform 0.3s ease,
                box-shadow 0.3s ease;
            animation: chipIn 0.5s ease both;
            animation-delay: var(--delay);
        }

        @supports (animation-timeline: view()) {
            .interests-list li {
                animation: chipIn linear both;
                animation-timeline: view();
                animation-range: entry 0% cover 20%;
            }
        }

        @keyframes chipIn {
            from {
                opacity: 0;
                transform: translateY(8px) scale(0.96);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .interests-list li:hover {
            color: var(--text);
            border-color: var(--accent-hover-border);
            background-color: var(--accent-hover-bg);
            transform: translateY(-3px);
            box-shadow: 0 4px 12px color-mix(in srgb, var(--accent), transparent 88%);
        }

        .interest-icon {
            font-size: 0.6rem;
            color: var(--accent);
            opacity: 0.5;
            transition: opacity 0.3s ease;
            line-height: 1;
        }

        .interests-list li:hover .interest-icon {
            opacity: 1;
        }

        .interest-label {
            font-family: var(--font-mono);
            letter-spacing: 0.02em;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        @scope (.interests) {
            .interests-list li {
                animation: none;
                opacity: 1;
            }

            .interests-list li:hover {
                transform: none;
            }
        }
    }
</style>
