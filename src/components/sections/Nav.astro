---

<nav aria-label="Navegación principal" class="fade-in">
    <a href="/" class="logo" aria-label="Portafolio">Portafolio</a>
</nav>

<style>
    @scope ( nav ) {
        :scope {
            position: sticky;
            top: 0;
            z-index: 100;
            padding-block: 1.5rem;
            padding-inline: 2rem;
            margin-block-end: 3rem;
            background-color: transparent;
            backdrop-filter: blur(12px);
            box-shadow: 0 15px 40px -10px color-mix(in srgb, var(--text), transparent 95%);
        }

        .logo {
            font-weight: 700;
            font-size: var(--text-xs);
            text-transform: uppercase;
            letter-spacing: 0.27em;
            color: var(--text);
            text-decoration: none;
        }
    }

    @media (max-width: 600px) {
        @scope ( nav ) {
            :scope {
                position: static;
                backdrop-filter: none;
                -webkit-backdrop-filter: none;
                box-shadow: none;
                margin-block-end: 0;
                padding: 1.25rem 1.5rem;
                border-block-end: 1px solid var(--card-border);
            }
        }
    }
</style>
