---
import MoonIcon from '../ui/icons/MoonIcon.astro';
import SunIcon from '../ui/icons/SunIcon.astro';
---

<nav aria-label="Navegación principal" class="fade-in">
    <a href="/" class="logo" aria-label="Portafolio">Portafolio</a>

    <button
        class="theme-toggle"
        type="button"
        aria-label="Cambiar entre modo claro y oscuro"
        title="Cambiar tema"
    >
        <SunIcon class="icon-sun" />
        <MoonIcon class="icon-moon" />
    </button>
</nav>

<style>
    @scope ( nav ) {
        :scope {
            position: sticky;
            top: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding-block: 1.5rem;
            padding-inline: 2rem;
            margin-block-end: 3rem;
            background-color: transparent;
            backdrop-filter: blur(12px);
            box-shadow: 0 15px 40px -10px color-mix(in srgb, var(--text), transparent 95%);
        }

        .logo {
            font-weight: 700;
            font-size: var(--text-xs);
            text-transform: uppercase;
            letter-spacing: 0.27em;
            color: var(--text);
            text-decoration: none;
        }

        .theme-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            color: var(--text-muted);
            background-color: transparent;
            border: 1px solid transparent;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition:
                color 0.25s ease,
                border-color 0.25s ease,
                background-color 0.25s ease;
        }

        .theme-toggle:hover {
            color: var(--text);
            border-color: var(--card-border);
            background-color: var(--accent-hover-bg);
        }

        .theme-toggle :global(.icon-sun) {
            display: none;
        }
    }

    :global(html[data-theme='dark'] .theme-toggle .icon-sun) {
        display: block;
    }

    :global(html[data-theme='dark'] .theme-toggle .icon-moon) {
        display: none;
    }

    @media (prefers-color-scheme: dark) {
        :global(html:not([data-theme]) .theme-toggle .icon-sun) {
            display: block;
        }

        :global(html:not([data-theme]) .theme-toggle .icon-moon) {
            display: none;
        }
    }

    @media (max-width: 600px) {
        @scope ( nav ) {
            :scope {
                position: static;
                backdrop-filter: none;
                -webkit-backdrop-filter: none;
                box-shadow: none;
                margin-block-end: 0;
                padding: 1.25rem 1.5rem;
                border-block-end: 1px solid var(--card-border);
            }
        }
    }
</style>

<script>
    import '../../scripts/themeToggle';
</script>
