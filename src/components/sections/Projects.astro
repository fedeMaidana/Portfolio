---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { getProjectsForLocale, type Project } from '@/services/content';
import ProjectCard from '../features/projects/ProjectCard.astro';
import Card from '../ui/Card.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = await getProjectsForLocale(lang);
---

<Card class="projects" ariaLabelledby="projects-title">
    <h2 id="projects-title" class="projects-title">{t('projects.title')}</h2>

    <div class="work-grid" role="list">
        {
            projects.map((project: Project) => (
                <div role="listitem">
                    <ProjectCard project={project} />
                </div>
            ))
        }
    </div>
</Card>

<style>
    @scope ( .projects ) {
        .work-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1.5rem;
        }
    }
</style>
