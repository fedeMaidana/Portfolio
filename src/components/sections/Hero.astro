---
import profile from '@/assets/pictures/me.jpg';
import { Image } from 'astro:assets';
import Card from '../ui/Card.astro';
---

<Card tag="header" class="hero">
    <div class="hero-layout">
        <div class="hero-text">
            <div class="status-line">
                <span class="status-dot" aria-hidden="true"></span>
                <span class="status-label">Disponible para proyectos</span>
            </div>

            <hgroup>
                <h1>
                    <span class="first-name">Federico</span>
                    <em class="last-name">Maidana</em>
                </h1>
                <p class="role">Backend Developer</p>
            </hgroup>

            <div class="meta-row">
                <span class="location-pin" aria-hidden="true">◆</span>
                <span class="location">Mar del Plata, Argentina</span>
            </div>
        </div>

        <div class="profile-container">
            <div class="profile-ring">
                <Image
                    src={profile}
                    alt="Foto de Federico Maidana"
                    width={160}
                    height={160}
                    class="profile-img"
                    fetchpriority="high"
                    loading="eager"
                />
            </div>
        </div>
    </div>
</Card>

<style>
    @scope (.hero) {
        .hero-layout {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 2.5rem;
        }

        .hero-text {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        /* ─── Status ─── */

        .status-line {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background-color: oklch(72% 0.19 145);
            box-shadow: 0 0 6px oklch(72% 0.19 145 / 0.6);
            animation: pulse 2.5s ease-in-out infinite;
        }

        @keyframes pulse {
            0%,
            100% {
                opacity: 1;
            }
            50% {
                opacity: 0.4;
            }
        }

        .status-label {
            font-family: var(--font-mono);
            font-size: var(--text-xxs);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: oklch(72% 0.19 145);
        }

        /* ─── Title ─── */

        hgroup {
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }

        h1 {
            font-size: var(--text-h1);
            font-family: var(--font-serif);
            font-weight: 400;
            line-height: 1;
            display: flex;
        }

        .first-name {
            color: var(--text);
            margin-inline-end: 1rem;
        }

        .last-name {
            color: var(--accent);
        }

        .role {
            font-family: var(--font-mono);
            font-size: var(--text-xs);
            letter-spacing: var(--title-spacing);
            text-transform: uppercase;
            color: var(--text-muted);
            margin-block-start: 0.25rem;
        }

        /* ─── Location ─── */

        .meta-row {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .location-pin {
            font-size: 0.45rem;
            color: var(--accent);
            opacity: 0.6;
        }

        .location {
            font-size: var(--text-xxs);
            letter-spacing: var(--title-spacing);
            text-transform: uppercase;
            color: var(--text-muted);
        }

        /* ─── Profile ─── */

        .profile-container {
            flex-shrink: 0;
        }

        .profile-ring {
            padding: 3px;
            border-radius: 50%;
            background: linear-gradient(
                135deg,
                color-mix(in srgb, var(--accent), transparent 60%),
                color-mix(in srgb, var(--card-border) 50%, transparent)
            );
        }

        .profile-img {
            width: 140px;
            height: 140px;
            object-fit: cover;
            border-radius: 50%;
            display: block;
            filter: grayscale(15%) contrast(1.04);
            transition: filter 0.4s ease;
        }

        :scope:hover .profile-img {
            filter: grayscale(0%) contrast(1);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        @scope (.hero) {
            .status-dot {
                animation: none;
            }
        }
    }

    @media (max-width: 600px) {
        @scope (.hero) {
            .hero-layout {
                flex-direction: column-reverse;
                align-items: flex-start;
                gap: 1.5rem;
            }

            .profile-img {
                width: 100px;
                height: 100px;
            }
        }
    }
</style>
