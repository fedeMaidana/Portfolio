---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import Card from '../ui/Card.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const socials = [
    {
        label: 'GitHub',
        href: 'https://www.github.com/fedeMaidana',
        rel: 'noopener noreferrer',
    },
    {
        label: 'LinkedIn',
        href: 'https://www.linkedin.com/in/fede-maidana/',
        rel: 'noopener noreferrer',
    },
];
---

<Card tag="footer" class="contact" ariaLabelledby="contact-title">
    <h2 id="contact-title" class="contact-title">{t('contact.title')}</h2>

    <p class="contact-cta">
        {t('contact.cta.1')}<strong>Rust</strong>{t('contact.cta.2')}
    </p>

    <form id="contact-form" class="contact-form" aria-label={t('contact.form.aria')} novalidate>
        <div class="field">
            <label for="cf-name">{t('contact.form.name')}</label>
            <input
                id="cf-name"
                name="name"
                type="text"
                autocomplete="name"
                required
                aria-describedby="cf-name-error"
            />
            <p id="cf-name-error" class="field-error" aria-live="polite"></p>
        </div>

        <div class="field">
            <label for="cf-email">{t('contact.form.email')}</label>
            <input
                id="cf-email"
                name="email"
                type="email"
                autocomplete="email"
                required
                aria-describedby="cf-email-error"
            />
            <p id="cf-email-error" class="field-error" aria-live="polite"></p>
        </div>

        <div class="field">
            <label for="cf-message">{t('contact.form.message')}</label>
            <textarea
                id="cf-message"
                name="message"
                rows="4"
                required
                aria-describedby="cf-message-error"></textarea>
            <p id="cf-message-error" class="field-error" aria-live="polite"></p>
        </div>

        <input
            type="checkbox"
            name="botcheck"
            class="botcheck"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
        />

        <button type="submit" class="submit-btn" aria-disabled="true">
            <span class="btn-label">{t('contact.form.submit')}</span>
            <span class="btn-arrow" aria-hidden="true">→</span>
        </button>

        <p class="form-status" role="status" aria-live="polite"></p>
    </form>

    <address class="contact-links">
        {
            socials.map(({ label, href, rel }, i) => (
                <a href={href} rel={rel} target="_blank" style={`--i: ${i}`}>
                    <span class="link-label">{label}</span>
                    <span class="link-arrow" aria-hidden="true">
                        ↗
                    </span>
                </a>
            ))
        }
    </address>

    <p class="contact-footnote">
        <span class="footnote-marker" aria-hidden="true">◆</span>
        {t('contact.footnote')}
    </p>
</Card>

<style>
    @scope (.contact) {
        /* ─── CTA ─── */

        .contact-cta {
            font-size: var(--text-sm);
            line-height: 1.7;
            color: color-mix(in srgb, var(--text), transparent 25%);
            max-width: 44ch;
            margin-block-end: 1.75rem;

            & strong {
                color: var(--accent);
                font-weight: 600;
            }
        }

        /* ─── Form ─── */

        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-block-end: 2rem;
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .field label {
            font-family: var(--font-mono);
            font-size: var(--text-xxs);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
        }

        .field input,
        .field textarea {
            font-family: var(--font-mono);
            font-size: var(--text-sm);
            color: var(--text);
            background-color: color-mix(in srgb, var(--card-bg) 40%, transparent);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-sm);
            padding: 0.7rem 0.85rem;
            width: 100%;
            transition:
                border-color 0.25s ease,
                background-color 0.25s ease;
        }

        .field textarea {
            resize: vertical;
            min-height: 6rem;
            line-height: 1.6;
        }

        .field input::placeholder,
        .field textarea::placeholder {
            color: color-mix(in srgb, var(--text-muted), transparent 35%);
        }

        .field input:focus-visible,
        .field textarea:focus-visible {
            outline: none;
            border-color: var(--accent-hover-border);
            background-color: var(--accent-hover-bg);
        }

        .field input[aria-invalid='true'],
        .field textarea[aria-invalid='true'] {
            border-color: color-mix(in srgb, var(--color-error), transparent 20%);
        }

        .field input[aria-invalid='true']:focus-visible,
        .field textarea[aria-invalid='true']:focus-visible {
            border-color: var(--color-error);
        }

        .field-error {
            font-family: var(--font-mono);
            font-size: var(--text-xxs);
            line-height: 1.4;
            color: var(--color-error);
            margin: 0;
        }

        .field-error:empty {
            display: none;
        }

        .botcheck {
            position: absolute;
            left: -9999px;
            width: 1px;
            height: 1px;
            opacity: 0;
            pointer-events: none;
        }

        /* ─── Submit ─── */

        .submit-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            align-self: flex-start;
            font-family: var(--font-mono);
            font-size: var(--text-xs);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--bg);
            background-color: var(--accent);
            border: 1px solid var(--accent);
            border-radius: var(--radius-sm);
            padding: 0.7rem 1.4rem;
            cursor: pointer;
            transition:
                opacity 0.25s ease,
                transform 0.25s ease;
        }

        .submit-btn:hover:not(:disabled):not([aria-disabled='true']) {
            opacity: 0.85;
            transform: translateY(-2px);
        }

        .submit-btn:focus-visible {
            outline: 1px solid var(--accent);
            outline-offset: 4px;
        }

        .submit-btn[aria-disabled='true'] {
            background-color: color-mix(in srgb, var(--text-muted), transparent 65%);
            border-color: transparent;
            color: var(--text-muted);
            cursor: not-allowed;
            transform: none;
        }

        .submit-btn:disabled {
            opacity: 0.55;
            cursor: progress;
            transform: none;
        }

        .btn-arrow {
            transition: transform 0.25s ease;
        }

        .submit-btn:hover:not(:disabled):not([aria-disabled='true']) .btn-arrow {
            transform: translateX(3px);
        }

        /* ─── Status ─── */

        .form-status {
            font-family: var(--font-mono);
            font-size: var(--text-xs);
            line-height: 1.5;
            min-height: 1.2em;
            margin: 0;
        }

        .form-status:empty {
            display: none;
        }

        .form-status[data-kind='ok'] {
            color: var(--color-ok);
        }

        .form-status[data-kind='error'] {
            color: var(--color-error);
        }

        /* ─── Social links ─── */

        .contact-links {
            display: flex;
            flex-direction: column;
            gap: 0;
            font-style: normal;
            margin-block-end: 1.5rem;
            border-block-start: 1px solid color-mix(in srgb, var(--card-border), transparent 40%);
            padding-block-start: 0.5rem;
        }

        .contact-links a {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.85rem 1rem;
            font-family: var(--font-mono);
            font-size: var(--text-sm);
            color: var(--text-muted);
            text-decoration: none;
            border-radius: var(--radius-sm);
            transition:
                color 0.25s ease,
                background-color 0.25s ease,
                padding-inline-start 0.25s ease;
        }

        .contact-links a:not(:last-child) {
            border-bottom: 1px solid color-mix(in srgb, var(--card-border), transparent 50%);
        }

        .contact-links a:hover {
            color: var(--text);
            background-color: var(--accent-hover-bg);
            padding-inline-start: 1.25rem;
        }

        .link-label {
            letter-spacing: 0.02em;
        }

        .link-arrow {
            font-size: var(--text-xs);
            color: var(--accent);
            opacity: 0;
            transform: translateX(-4px);
            transition:
                opacity 0.25s ease,
                transform 0.25s ease;
        }

        .contact-links a:hover .link-arrow {
            opacity: 0.7;
            transform: translateX(0);
        }

        /* ─── Footnote ─── */

        .contact-footnote {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            font-family: var(--font-mono);
            font-size: var(--text-xxs);
            color: var(--text-muted);
            letter-spacing: 0.04em;
            opacity: 0.7;
        }

        .footnote-marker {
            font-size: 0.4rem;
            color: var(--accent);
            opacity: 0.6;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        @scope (.contact) {
            .submit-btn:hover:not(:disabled):not([aria-disabled='true']) {
                transform: none;
            }

            .submit-btn:hover:not(:disabled):not([aria-disabled='true']) .btn-arrow {
                transform: none;
            }
        }
    }

    @media (max-width: 600px) {
        @scope (.contact) {
            .contact-cta {
                max-width: 100%;
            }

            .submit-btn {
                align-self: stretch;
            }

            .contact-links a {
                padding: 0.75rem 0.75rem;
            }

            .contact-links a:hover {
                padding-inline-start: 1rem;
            }
        }
    }
</style>

<script>
    import '../../scripts/contactForm';
</script>
