{
    "name": "portfolio_astro",
    "type": "module",
    "private": true,
    "packageManager": "bun@1.3.10",
    "engines": {
        "node": ">=18.0.0",
        "bun": ">=1.0.0"
    },
    "scripts": {
        "test": "echo \"Error: not test specified\" && exit 1",
        "dev": "bun x --bun astro dev",
        "build": "bun x --bun astro build",
        "preview": "bun x --bun astro preview",
        "prepare": "husky"
    },
    "dependencies": {
        "@astrojs/sitemap": "^3.7.0",
        "@fontsource/instrument-serif": "^5.2.8",
        "@fontsource/space-mono": "^5.2.9",
        "@vercel/analytics": "^1.6.1",
        "@vercel/speed-insights": "^1.3.1",
        "astro": "^5.18.0",
        "sitemap": "^9.0.1"
    },
    "devDependencies": {
        "astro-eslint-parser": "^1.3.0",
        "eslint": "^10.0.2",
        "eslint-plugin-astro": "^1.6.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "husky": "^9.1.7",
        "lightningcss": "^1.31.1",
        "lint-staged": "^16.3.1",
        "prettier": "^3.8.1",
        "prettier-plugin-astro": "^0.14.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "lint-staged": {
        "*.{astro,ts,mts,js,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,css}": [
            "prettier --write"
        ]
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead"
    ]
}
